{
  "imports": {
    "lume/": "https://deno.land/x/lume@v2.2.1/",
    "lume_icon_plugins/": "https://deno.land/x/lume_icon_plugins@v0.2.3/"
  },
  "tasks": {
    "lume": "echo \"import 'lume/cli.ts'\" | deno run -A -",
    "build": "deno task lume",
    "serve": "deno task lume -s -w"
  },
  "compilerOptions": {
    "types": ["lume/types.ts"]
  }
}
