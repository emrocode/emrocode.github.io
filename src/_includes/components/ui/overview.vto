<article class="activity">
  <div>
    <h3 class="activity-title">
      {{ activity.title }}
    </h3>
    <a
      class="activity-link"
      href="{{ activity.url }}"
      >{{ `${activity.repository.owner}/${activity.repository.name}` }}</a
    >
  </div>
  <p class="activity-description">{{ activity.description }}</p>
  <style>
    .activity-title {
      --space: 0.25rem;
      font-size: var(--font-mx);
      font-weight: bold;
      margin-bottom: var(--space);
      display: flex;
      gap: var(--space);
      flex-wrap: wrap;
    }

    .activity-link {
      font-size: var(--font-sm);
      text-decoration: underline;
      color: var(--ttcolor);
      &:is(:hover, :focus) {
        color: inherit;
      }
    }

    .activity-description {
      font-size: var(--font-sm);
      text-wrap: pretty;
    }
  </style>
</article>
